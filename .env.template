# ──────────────────────────────────────────────────────────────────────────────
# 7-Agent Price Intelligence Dashboard — Environment Variables Template
# Author: Lalit Nayyar <lalitnayyar@gmail.com>
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_TITLE=7-Agent Price Intelligence Dashboard
APP_VERSION=1.0.0
DASHBOARD_PORT=3000
DEV_PORT=5173
TZ=UTC

# ── LLM API Keys ──────────────────────────────────────────────────────────────
# OpenAI — used by FrontierAgent (gpt-4o-mini), AutonomousPlannerAgent (gpt-4o), ScannerAgent
OPENAI_API_KEY=sk-...

# Anthropic — used by MessagingAgent (claude-sonnet-4-5)
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek — optional alternative to OpenAI
DEEPSEEK_API_KEY=sk-...

# ── Modal.com ─────────────────────────────────────────────────────────────────
# Get from: modal.com → Settings → Tokens → New Token
MODAL_TOKEN_ID=ak-...
MODAL_TOKEN_SECRET=as-...

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Get from: huggingface.co/settings/tokens
HF_TOKEN=hf_...
HF_USER=your-username

# ── Pushover Push Notifications ───────────────────────────────────────────────
# Get from: pushover.net (user key) and pushover.net/apps/build (app token)
PUSHOVER_USER=u...
PUSHOVER_TOKEN=a...

# ── ChromaDB & Local Services ─────────────────────────────────────────────────
CHROMA_DB_PATH=products_vectorstore
OLLAMA_BASE_URL=http://localhost:11434
PRICER_PREPROCESSOR_MODEL=ollama/llama3.2

# ── Deal Agent Settings ───────────────────────────────────────────────────────
# Minimum discount in USD to trigger a push notification
DEAL_THRESHOLD=50
# Number of ChromaDB embeddings for t-SNE visualization
MAX_DATAPOINTS=2000

# ── Fine-tuned Model Config ───────────────────────────────────────────────────
BASE_MODEL=meta-llama/Llama-3.2-3B
FINETUNED_MODEL=ed-donner/price-2025-11-28_18.47.07
RUN_NAME=2025-11-28_18.47.07
REVISION=b19c8bfea3b6ff62237fbb0a8da9779fc12cefbd
GPU=T4

# ── Backend (optional, for real agent execution) ──────────────────────────────
BACKEND_PORT=8000
LOG_LEVEL=INFO

# ── Log Viewer (optional Dozzle) ──────────────────────────────────────────────
LOG_PORT=9999
